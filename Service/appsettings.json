{
    "FireBox": {
        "StorageRootPath": "%LOCALAPPDATA%\\FireBox",
        "DatabaseFileName": "firebox.db",
        "ComErrorLogFileName": "service-com-errors.log",
        "SingleInstanceMutexName": "Local\\FireBox.Service.Singleton",
        "AccessDenyCooldownHours": 24,
        "TrustedClientProcessNames": [
            "App"
        ],
        "DefaultProviderBaseUrls": {
            "OpenAI": "https://api.openai.com/v1",
            "Anthropic": "https://api.anthropic.com",
            "Gemini": "https://generativelanguage.googleapis.com"
        },
        "AnthropicKnownModels": [
            "claude-opus-4-0",
            "claude-sonnet-4-5",
            "claude-sonnet-4-0",
            "claude-haiku-4-5",
            "claude-3-5-sonnet-20241022",
            "claude-3-5-haiku-20241022"
        ]
    }
}