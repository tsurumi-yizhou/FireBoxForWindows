<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Demo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="SettingsSectionSpacing">12</x:Double>

        <Style x:Key="SettingsSectionExpanderStyle"
               TargetType="controls:SettingsExpander">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="RootScrollViewer"
                  IsTabStop="True"
                  HorizontalContentAlignment="Stretch"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid x:Name="SettingsRootContainer"
              Margin="32,20,32,24">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="NarrowState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SettingsRootContainer.Margin" Value="16,16,16,20" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="MediumState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="900" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SettingsRootContainer.Margin" Value="24,18,24,22" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1200" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="SettingsRootContainer.Margin" Value="32,20,32,24" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsLeftSpacerColumn"
                                      Width="191*" />
                    <ColumnDefinition x:Name="SettingsContentColumn"
                                      Width="618*" />
                    <ColumnDefinition x:Name="SettingsRightSpacerColumn"
                                      Width="191*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1"
                            Spacing="{StaticResource SettingsSectionSpacing}">
                    <SelectorBar x:Name="SettingsSelectorBar"
                                 SelectionChanged="SettingsSelectorBar_SelectionChanged">
                        <SelectorBarItem x:Name="GeneralSelectorItem"
                                         IsSelected="True" />
                        <SelectorBarItem x:Name="AboutSelectorItem" />
                    </SelectorBar>

                    <Grid>
                        <StackPanel x:Name="GeneralContentPanel"
                                    Spacing="{StaticResource SettingsSectionSpacing}">
                            <controls:SettingsExpander x:Name="GeneralSectionExpander"
                                                       Style="{StaticResource SettingsSectionExpanderStyle}">
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Name="ModelAutoRefreshCard">
                                        <ToggleSwitch IsOn="True" />
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>

                            <controls:SettingsExpander x:Name="ReasoningSectionExpander"
                                                       Style="{StaticResource SettingsSectionExpanderStyle}">
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Name="ThinkingIntensityCard"
                                                           HorizontalContentAlignment="Left">
                                        <ComboBox SelectedIndex="0"
                                                  Width="220">
                                            <ComboBoxItem x:Name="ThinkingDefaultOption" />
                                            <ComboBoxItem x:Name="ThinkingLowOption" />
                                            <ComboBoxItem x:Name="ThinkingMediumOption" />
                                            <ComboBoxItem x:Name="ThinkingHighOption" />
                                            <ComboBoxItem x:Name="ThinkingMaxOption" />
                                        </ComboBox>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>

                            <controls:SettingsExpander x:Name="ComposerSectionExpander"
                                                       Style="{StaticResource SettingsSectionExpanderStyle}">
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Name="CompactComposerCard">
                                        <ToggleSwitch IsOn="True" />
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </StackPanel>

                        <StackPanel x:Name="AboutContentPanel"
                                    Visibility="Collapsed"
                                    Spacing="{StaticResource SettingsSectionSpacing}">
                            <controls:SettingsCard x:Name="AboutAppCard">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="AboutAppNameValueText" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="AboutVersionLabelText"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="AboutVersionValueText"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </controls:SettingsCard>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
