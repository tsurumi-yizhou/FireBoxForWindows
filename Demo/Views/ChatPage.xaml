<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Demo.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Demo.Models"
    mc:Ignorable="d"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <UserControl.Resources>
        <MenuFlyout x:Name="MessageBubbleMenuFlyout"
                    Closed="MessageBubbleMenuFlyout_Closed">
            <MenuFlyoutItem x:Name="MessageBubbleSelectAllMenuItem"
                            Click="MessageBubbleSelectAllMenuItem_Click" />
            <MenuFlyoutItem x:Name="MessageBubbleCopyMenuItem"
                            Click="MessageBubbleCopyMenuItem_Click" />
            <MenuFlyoutItem x:Name="MessageBubbleRetryMenuItem"
                            Click="MessageBubbleRetryMenuItem_Click">
                <MenuFlyoutItem.Icon>
                    <SymbolIcon Symbol="Refresh" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem x:Name="MessageBubbleDeleteMenuItem"
                            Click="MessageBubbleDeleteMenuItem_Click">
                <MenuFlyoutItem.Icon>
                    <SymbolIcon Symbol="Delete" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </UserControl.Resources>

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{x:Bind ViewModel.ActiveConversationTitle, Mode=OneWay}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <ComboBox x:Name="ModelSelector"
                          Width="220"
                          HorizontalAlignment="Right"
                          PlaceholderText="Select a model"
                          SelectionChanged="ModelSelector_SelectionChanged" />

                <ComboBox x:Name="ReasoningEffortSelector"
                          Width="172"
                          HorizontalAlignment="Right"
                          PlaceholderText="Thinking intensity"
                          DisplayMemberPath="Label"
                          ItemsSource="{x:Bind ViewModel.ReasoningEffortOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedReasoningEffort, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <InfoBar x:Name="FeedbackBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"
                 Closed="FeedbackBar_Closed" />

        <!-- Messages list -->
        <ListView x:Name="MessageList"
                  Grid.Row="2"
                  Padding="0,0,12,0"
                  SelectionMode="None"
                  ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatUiMessage">
                    <StackPanel HorizontalAlignment="{x:Bind BubbleHorizontalAlignment, Mode=OneWay}"
                                Margin="{x:Bind BubbleOuterMargin, Mode=OneWay}"
                                Spacing="4"
                                MaxWidth="760"
                                ContextRequested="MessageBubble_ContextRequested">
                        <Border Padding="14,10"
                                CornerRadius="{x:Bind BubbleCornerRadius, Mode=OneWay}"
                                Background="{x:Bind BubbleBackground, Mode=OneWay}">
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords"
                                               IsTextSelectionEnabled="True"
                                               ContextFlyout="{x:Null}"
                                               Visibility="{x:Bind PlainTextVisibility, Mode=OneWay}"
                                               Foreground="{x:Bind MessageForeground, Mode=OneWay}" />

                                    <controls:MarkdownTextBlock Text="{x:Bind Content, Mode=OneWay}"
                                                                TextWrapping="WrapWholeWords"
                                                                IsTextSelectionEnabled="True"
                                                                ContextFlyout="{x:Null}"
                                                                Visibility="{x:Bind MarkdownVisibility, Mode=OneWay}"
                                                                FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                                                Foreground="{x:Bind MessageForeground, Mode=OneWay}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="0"
                                                                LinkClicked="MarkdownMessage_LinkClicked" />
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind AttachmentItems, Mode=OneWay}"
                                              Visibility="{x:Bind AttachmentVisibility, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:ChatUiAttachmentItem">
                                            <Border Padding="6"
                                                    CornerRadius="4"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                <StackPanel Spacing="4">
                                                    <Image Source="{x:Bind PreviewImage, Mode=OneWay}"
                                                           Visibility="{x:Bind PreviewVisibility, Mode=OneWay}"
                                                           Stretch="UniformToFill"
                                                           MaxWidth="280"
                                                           MaxHeight="180" />

                                                    <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,3" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <StackPanel Grid.Row="3" Spacing="6">
            <Border Padding="8"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="AttachmentRail"
                            Grid.Row="0"
                            Padding="6"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollMode="Enabled"
                                      HorizontalScrollMode="Disabled"
                                      MaxHeight="108">
                            <StackPanel x:Name="AttachmentListPanel"
                                        Spacing="4" />
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PickFileButton"
                                Grid.Column="0"
                                Width="40"
                                Height="40"
                                Padding="0"
                                ToolTipService.ToolTip="Upload file"
                                Click="PickFileButton_Click">
                            <SymbolIcon Symbol="Upload" />
                        </Button>

                        <Border Grid.Column="1"
                                Height="40"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <TextBox x:Name="InputBox"
                                     PlaceholderText="Type your message..."
                                     AcceptsReturn="False"
                                     KeyDown="InputBox_KeyDown"
                                     MinHeight="40"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,6"
                                     Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>

                        <Button x:Name="SendButton"
                                Grid.Column="2"
                                Width="40"
                                Height="40"
                                Padding="0"
                                Click="SendButton_Click"
                                IsEnabled="{x:Bind ViewModel.CanSubmitOrAbort, Mode=OneWay}"
                                Style="{ThemeResource AccentButtonStyle}">
                            <Viewbox Width="18" Height="18">
                                <SymbolIcon Symbol="{x:Bind ViewModel.SendButtonSymbol, Mode=OneWay}" />
                            </Viewbox>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
