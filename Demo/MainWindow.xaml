<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Demo"
    xmlns:views="using:Demo.Views"
    Title="FireBox Demo">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center"
                            Margin="16,0,20,0">
                    <FontIcon Glyph="&#xE8BD;" FontSize="16" />
                    <StackPanel Spacing="0" VerticalAlignment="Center">
                        <TextBlock Text="FireBox Demo"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Chat Playground"
                                   FontSize="11"
                                   Opacity="0.72" />
                    </StackPanel>
                </StackPanel>

                <Grid x:Name="TitleBarDragRegion" Grid.Column="1" />
            </Grid>
        </Border>

        <InfoBar x:Name="StatusBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0" />

        <NavigationView x:Name="ConversationNavView"
                        Grid.Row="2"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        CompactPaneLength="48"
                        OpenPaneLength="320"
                        SelectionChanged="ConversationNavView_SelectionChanged">
            <NavigationView.PaneHeader>
                <Grid Margin="12,8,12,0">
                    <Button x:Name="NewChatButton"
                            HorizontalAlignment="Right"
                            Content="&#xE710;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="New Chat"
                            Click="NewChat_Click"
                            Style="{ThemeResource AccentButtonStyle}">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="N" />
                        </Button.KeyboardAccelerators>
                    </Button>
                </Grid>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="40"
                          Padding="0,0,8,0">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Delete"
                                                Icon="Delete"
                                                Click="DeleteConversationMenuItem_Click"
                                                Tag="{Binding Id}" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <TextBlock
                                   Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </NavigationView.MenuItemTemplate>

            <views:ChatPage x:Name="ChatPageView" />
        </NavigationView>
    </Grid>
</Window>
