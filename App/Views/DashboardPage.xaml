<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}" />
            <Button Grid.Column="1" Content="Refresh" Click="RefreshButton_Click" />
        </Grid>

        <InfoBar x:Name="StatusBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational" />

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="24">
                <!-- Today -->
                <TextBlock Text="Today" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Requests" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TodayRequests" Text="0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Tokens" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TodayTokens" Text="0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Cost (USD)" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TodayCost" Text="$0.00" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- This Month -->
                <TextBlock Text="This Month" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Requests" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="MonthRequests" Text="0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Tokens" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="MonthTokens" Text="0" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel Padding="16" Spacing="4">
                            <TextBlock Text="Cost (USD)" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="MonthCost" Text="$0.00" FontSize="28" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
